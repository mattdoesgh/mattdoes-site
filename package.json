{
  "name": "mattdoes-site",
  "version": "0.1.0",
  "private": true,
  "description": "mattdoes.online — Obsidian vault → static HTML",
  "type": "module",
  "scripts": {
    "postinstall": "npm --prefix design-system ci --include=dev",
    "build:ssg": "npm --prefix design-system run build:ssg",
    "prebuild": "npm run build:ssg",
    "build": "NODE_ENV=production node build.js",
    "clean": "rm -rf dist design-system/dist-ssg",
    "lint": "html-validate \"dist/**/*.html\"",
    "audit": "npm audit --audit-level=moderate",
    "check:assets": "node scripts/check-asset-budget.js",
    "perf:lighthouse": "npx --yes @lhci/cli autorun --config=testing-suites/lighthouse/lighthouserc.cjs",
    "scan:secrets": "npx --yes gitleaks detect --source . --verbose",
    "pretest": "npm run build:ssg && NODE_ENV=production LISTENING_OFFLINE=1 VAULT_DIR=test/fixture-vault SITE_URL=https://mattdoes.online node build.js",
    "test": "node --test \"test/**/*.test.js\"",
    "deploy:workers": "cd workers/listening && npx wrangler deploy && cd ../geo && npx wrangler deploy && cd ../csp-report && npx wrangler deploy",
    "bake-geo": "node scripts/bake-home-geojson.js",
    "optimize-media": "node scripts/optimize-media.js",
    "sync-media": "node --env-file-if-exists=.env scripts/sync-media.js"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "marked-footnote": "^1.4.0",
    "sanitize-html": "^2.17.5",
    "shiki": "^4.2.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "axe-core": "^4.12.1",
    "culori": "^4.0.2",
    "html-validate": "^11.5.3",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "sharp": "^0.35.2",
    "terser": "^5.48.0"
  }
}
