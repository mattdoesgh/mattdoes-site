{
  "name": "mattdoes-site",
  "version": "0.1.0",
  "private": true,
  "description": "mattdoes.online — Obsidian vault → static HTML",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "clean": "rm -rf dist",
    "lint": "html-validate \"dist/**/*.html\"",
    "audit": "npm audit --audit-level=moderate",
    "bake-geo": "node scripts/bake-home-geojson.js",
    "optimize-media": "node scripts/optimize-media.js",
    "sync-media": "node --env-file-if-exists=.env scripts/sync-media.js"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "html-validate": "^10.16.0",
    "lightningcss": "^1.32.0",
    "sharp": "^0.34.5",
    "terser": "^5.47.1"
  }
}
