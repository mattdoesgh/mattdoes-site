{
  "name": "mattdoes-site",
  "version": "0.1.0",
  "private": true,
  "description": "mattdoes.online — Obsidian vault → static HTML",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "clean": "rm -rf dist",
    "lint": "html-validate \"dist/**/*.html\"",
    "audit": "npm audit --audit-level=moderate",
    "pretest": "VAULT_DIR=test/fixture-vault SITE_URL=https://mattdoes.online node build.js",
    "test": "node --test --test-concurrency=1 \"test/**/*.test.js\"",
    "bake-geo": "node scripts/bake-home-geojson.js",
    "optimize-media": "node scripts/optimize-media.js",
    "sync-media": "node --env-file-if-exists=.env scripts/sync-media.js"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^18.0.4",
    "marked-footnote": "^1.4.0",
    "shiki": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "axe-core": "^4.11.4",
    "culori": "^4.0.2",
    "html-validate": "^11.4.0",
    "jsdom": "^25.0.1",
    "lightningcss": "^1.32.0",
    "sharp": "^0.34.5",
    "terser": "^5.48.0"
  }
}
