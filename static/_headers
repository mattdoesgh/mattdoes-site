# Cloudflare Pages — response headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; img-src 'self' https://media.mattdoes.online data:; media-src 'self' https://media.mattdoes.online; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; frame-ancestors 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

# Fonts — immutable, long cache
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS — long cache (content-hashed filenames flush by rename)
/*.css
  Cache-Control: public, max-age=31536000, immutable

# JS — long cache (content-hashed filenames flush by rename)
/*.js
  Cache-Control: public, max-age=31536000, immutable

# Feeds — short cache so new entries show up
/feed.xml
  Cache-Control: public, max-age=300, s-maxage=300

# HTML pages — let the edge cache briefly, revalidate often
/*.html
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate
