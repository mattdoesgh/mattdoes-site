# Cloudflare Pages — response headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  # Permissions-Policy: geolocation is allowed for self only — the opt-in
  # city map in the tweaks panel reverse-geocodes the visitor's coords.
  # Every other powerful feature the site does not use is explicitly denied,
  # plus the interest-cohort / browsing-topics opt-outs.
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=(), usb=(), midi=(), magnetometer=(), accelerometer=(), gyroscope=(), display-capture=(), screen-wake-lock=(), xr-spatial-tracking=(), serial=(), bluetooth=(), hid=(), interest-cohort=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # CSP keeps style-src strict: Shiki highlighted-code tokens are emitted as
  # build-time CSS classes (lib/shiki-csp.js) instead of inline style attributes.
  # Report-only twin collects any regressions before enforcement changes.
  # The build (lib/emit.js → injectImportmapCsp) appends the inline importmap's
  # sha256 to script-src in the emitted dist/_headers — script-src carries no
  # inline keyword, so an unhashed importmap is dropped and every module that
  # imports through it dies (ADR 0001). Don't hardcode that hash here: it moves
  # with the hashed rows.js/_helpers.js URLs and is recomputed each build.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'inline-speculation-rules'; img-src 'self' https://media.mattdoes.online data:; media-src 'self' https://media.mattdoes.online; style-src 'self'; font-src 'self'; connect-src 'self'; frame-ancestors 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  # Report-only twin of the enforced CSP — collects browser violations at the
  # same-origin /api/csp-report Worker before tightening style-src.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'inline-speculation-rules'; img-src 'self' https://media.mattdoes.online data:; media-src 'self' https://media.mattdoes.online; style-src 'self'; font-src 'self'; connect-src 'self'; frame-ancestors 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; report-uri https://mattdoes.online/api/csp-report

# ── Immutable, content-hashed assets ────────────────────────────────────
# Browser AND edge cache for a year. `immutable` tells browsers not to
# revalidate on reload. CDN-Cache-Control lets us tune the edge tier
# independently if we ever want to (Cloudflare reads it ahead of
# Cache-Control). Source: https://developers.cloudflare.com/cache/concepts/cache-control/

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/*.css
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000, immutable

# ── Build-baked data ────────────────────────────────────────────────────
# Day-long edge cache, 1h browser cache. Re-baked GeoJSON propagates with
# the next deploy (Pages purges the edge); browsers revalidate hourly so
# returning visitors pick up changes without a hard refresh.
/*.geojson
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# ── Feeds ───────────────────────────────────────────────────────────────
/feed.xml
  Cache-Control: public, max-age=900, stale-while-revalidate=3600
  CDN-Cache-Control: public, max-age=1800, stale-while-revalidate=86400

# ── HTML pages ──────────────────────────────────────────────────────────
# 0 browser TTL + long edge TTL with stale-while-revalidate. Pages purges
# the edge on deploy, so a 6h s-maxage is safe and dramatically lifts
# edge hit rate for repeat visitors that already have the asset shell
# cached. 103 Early Hints push the shell preloads while origin renders.
# Only the critical JetBrains Mono Regular face is preloaded — it is the sole
# font on the critical render path (see static/_shared.css @font-face rules).
/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, s-maxage=21600, stale-while-revalidate=604800
  Link: </fonts/JetBrainsMono-Regular.woff2>; rel=preload; as=font; type=font/woff2; crossorigin

/*/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, s-maxage=21600, stale-while-revalidate=604800
  Link: </fonts/JetBrainsMono-Regular.woff2>; rel=preload; as=font; type=font/woff2; crossorigin

/*.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, s-maxage=21600, stale-while-revalidate=604800
