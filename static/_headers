# Cloudflare Pages — response headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; img-src 'self' https://media.mattdoes.online data:; media-src 'self' https://media.mattdoes.online; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; frame-ancestors 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

# Fonts — immutable, long cache
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS — long cache (content-hashed filenames flush by rename)
/*.css
  Cache-Control: public, max-age=31536000, immutable

# JS — long cache (content-hashed filenames flush by rename)
/*.js
  Cache-Control: public, max-age=31536000, immutable

# Baked GeoJSON — re-baked rarely (run `npm run bake-geo`); not
# content-hashed because the URL is referenced by /static/geo-background.js
# at runtime. Browser revalidates hourly; edge holds a day with a week of
# stale-while-revalidate, so a re-bake propagates within a few minutes of
# the next deploy (Pages purges on deploy) and normal traffic skips re-fetching.
/*.geojson
  Cache-Control: public, max-age=3600
  CDN-Cache-Control: public, s-maxage=86400, stale-while-revalidate=604800

# Feeds — readers refresh on their own cadence; let the edge absorb most
# of it (1h s-maxage + 1d SWR) while browsers/feed-readers still see a
# 30-minute browser TTL.
/feed.xml
  Cache-Control: public, max-age=1800
  CDN-Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

# HTML pages — browser always revalidates (so a deploy is visible on the
# next request), edge holds 6h with a week of stale-while-revalidate.
# Cloudflare Pages purges the edge on every deploy, so the long SWR
# can't serve content from a prior deploy. Three patterns cover root,
# clean directory URLs, and any literal *.html.
/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, s-maxage=21600, stale-while-revalidate=604800
/*/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, s-maxage=21600, stale-while-revalidate=604800
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, s-maxage=21600, stale-while-revalidate=604800
